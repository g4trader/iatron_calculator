# Iatron environment template
# Copy to .env.local for local development or configure these values in Vercel/Supabase environments.

# Environment marker used by operational scripts. Use: local, staging, e2e, production.
IATRON_ENV=local

# Backend clinical API
NEXT_PUBLIC_API_URL=http://localhost:8080

# Auth.js / NextAuth
AUTH_SECRET=change-me
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
TEMP_LOGIN_EMAIL=admin@example.com
TEMP_LOGIN_PASSWORD=change-me-temporary-password
# Optional multi-user temporary login. Format: email=password;email2=password2
TEMP_LOGIN_USERS=
# Temporary login is development-only and ignored in production unless the code is changed deliberately.
TEMP_LOGIN_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Transactional email. Resend is supported without an extra package.
RESEND_API_KEY=
EMAIL_FROM=Iatron <no-reply@iatron.app>

# Production rate limit store. Without this, rate limiting falls back to in-memory per instance.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Preferred GCP option for Vercel production/staging when Redis is not used.
RATE_LIMIT_PROVIDER=firestore
FIRESTORE_DATABASE_ID=(default)
RATE_LIMIT_FIRESTORE_COLLECTION=iatronRateLimits
# In production, memory fallback is denied unless explicitly enabled for emergency/dev-only use.
RATE_LIMIT_ALLOW_MEMORY_FALLBACK=false

# Active session enforcement
SESSION_IDLE_TIMEOUT_MINUTES=480
SESSION_ABSOLUTE_TIMEOUT_MINUTES=20160
SESSION_TOUCH_INTERVAL_SECONDS=60

# Database / ORM
# Local dev example:
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/iatron
#
# Supabase staging/E2E recommendation:
# DATABASE_URL should use the Supabase pooler/runtime connection when used by Vercel/serverless.
# DIRECT_URL should use the direct database connection for Prisma migrations.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/iatron?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/iatron?sslmode=require

# Playwright E2E
# Use app local with cloud DB: http://127.0.0.1:3000
# Or deployed staging URL: https://your-staging-domain.vercel.app
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
E2E_PASSWORD=IatronE2E#2026

# Stripe billing
# Staging/E2E must use Stripe test mode keys only.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_HOSPITAL_CUSTOM=

# Operational billing reconciliation
BILLING_RECONCILIATION_LIMIT=100
ALLOW_PRODUCTION_BILLING_RECONCILIATION=false

# Operational cleanup
REVOKED_SESSION_RETENTION_DAYS=90
SECURITY_EVENT_RETENTION_DAYS=180
CALCULATION_HISTORY_RETENTION_DAYS=365
ALLOW_PRODUCTION_SECURITY_CLEANUP=false

# Admin production readiness / private archive-export storage
# Production/staging final must use ARCHIVE_STORAGE_PROVIDER=gcs or s3 with a private bucket.
# local is only acceptable for development/test.
ARCHIVE_STORAGE_PROVIDER=gcs
ARCHIVE_STORAGE_DIR=/tmp/iatron-archives
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_EMAIL=
GCP_PRIVATE_KEY=
ARCHIVE_GCS_BUCKET=
ARCHIVE_GCS_PREFIX=iatron-admin-archives
ARCHIVE_S3_ENDPOINT=
ARCHIVE_S3_BUCKET=
ARCHIVE_S3_REGION=auto
ARCHIVE_S3_ACCESS_KEY_ID=
ARCHIVE_S3_SECRET_ACCESS_KEY=
ARCHIVE_S3_PREFIX=iatron-admin-archives
ADMIN_STAGING_BASE_URL=
ADMIN_READINESS_STRICT=false
# Dev-only compatibility for old exports without storageProvider. Do not enable in production.
ADMIN_EXPORT_ALLOW_INLINE_FALLBACK=false
